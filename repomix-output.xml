<!-- Chart.js from CDN — loaded before our script -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
(function () {
  'use strict';

  /* ── 1. Read Django data from json_script — the safe pattern ──────────
     json_script escapes HTML entities so malicious data can't break out
     of the <script type="application/json"> tag into live JS execution.
  ────────────────────────────────────────────────────────────────────── */
  const pieLabels   = JSON.parse(document.getElementById('js-pie-labels').textContent);
  const pieData     = JSON.parse(document.getElementById('js-pie-data').textContent);
  const dailyLabels = JSON.parse(document.getElementById('js-daily-labels').textContent);
  const dailyData   = JSON.parse(document.getElementById('js-daily-data').textContent);

  /* ── 2. Design tokens ─────────────────────────────────────────────── */
  const RED      = '#D42B2B';
  const FONT     = "'DM Sans', system-ui, sans-serif";
  const GRID_CLR = 'rgba(26,26,26,0.055)';
  const MUTED    = '#aaa';

  /* Status colour palette for the pie chart — order matches pie_map in views.py */
  const PIE_COLOURS = {
    'Published':     { bg: '#D42B2B', border: '#b82222' },
    'Draft':         { bg: '#94a3b8', border: '#7a8fa6' },
    'Pending Review':{ bg: '#f59e0b', border: '#d97706' },
    'Rejected':      { bg: '#ef4444', border: '#dc2626' },
  };

  Chart.defaults.font.family = FONT;
  Chart.defaults.font.size   = 12;
  Chart.defaults.color       = MUTED;

  /* ── 3. Doughnut / Pie chart ────────────────────────────────────────
     type: 'doughnut' leaves a hole in the centre where we overlay
     the total count using a CSS-positioned div (.ws-pie-centre).
     cutout: '68%' controls the hole size.
  ────────────────────────────────────────────────────────────────────── */
  const pieCanvas = document.getElementById('pieChart');
  if (pieCanvas && pieData.length > 0) {

    const bgColours     = pieLabels.map(l => (PIE_COLOURS[l] || PIE_COLOURS['Draft']).bg);
    const borderColours = pieLabels.map(l => (PIE_COLOURS[l] || PIE_COLOURS['Draft']).border);

    const pieChart = new Chart(pieCanvas, {
      type: 'doughnut',
      data: {
        labels: pieLabels,
        datasets: [{
          data:            pieData,
          backgroundColor: bgColours,
          borderColor:     borderColours,
          borderWidth:     2,
          hoverOffset:     6,
          /* Rounded segment ends */
          borderRadius:    4,
          spacing:         2,
        }]
      },
      options: {
        responsive:          false,   /* fixed size — we sized the canvas manually */
        maintainAspectRatio: false,
        cutout:              '68%',   /* doughnut hole size */
        plugins: {
          legend: { display: false }, /* we build our own legend below */
          tooltip: {
            backgroundColor: '#1a1a1a',
            titleColor:      '#fff',
            bodyColor:       'rgba(255,255,255,0.75)',
            padding:         12,
            cornerRadius:    8,
            callbacks: {
              label: ctx => {
                const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                const pct   = total > 0 ? Math.round((ctx.parsed / total) * 100) : 0;
                return '  ' + ctx.parsed + ' posts (' + pct + '%)';
              }
            }
          }
        }
      }
    });

    /* Build custom legend programmatically */
    const legendEl = document.getElementById('pieLegend');
    if (legendEl) {
      pieLabels.forEach(function (label, i) {
        const count = pieData[i];
        const total = pieData.reduce((a, b) => a + b, 0);
        const pct   = total > 0 ? Math.round((count / total) * 100) : 0;
        const colour = bgColours[i];

        const li = document.createElement('li');
        li.className = 'ws-legend-item';
        li.innerHTML =
          '<span class="ws-legend-dot" style="background:' + colour + '"></span>' +
          '<span class="ws-legend-label">' + label + '</span>' +
          '<span class="ws-legend-count">' + count + '</span>' +
          '<span class="ws-legend-pct">' + pct + '%</span>';
        legendEl.appendChild(li);
      });
    }
  }

  /* ── 4. Line chart — daily likes over 30 days ───────────────────────
     fill: true + gradient gives a soft area chart feel.
     tension: 0.35 makes it curve rather than zig-zag.
     We show a point only if it has data (pointRadius callback).
  ────────────────────────────────────────────────────────────────────── */
  const lineCanvas = document.getElementById('lineChart');
  if (lineCanvas) {
    const ctx = lineCanvas.getContext('2d');

    /* Gradient fill under the line — fades top-to-bottom */
    const grad = ctx.createLinearGradient(0, 0, 0, 240);
    grad.addColorStop(0,    'rgba(212,43,43,0.18)');
    grad.addColorStop(0.65, 'rgba(212,43,43,0.04)');
    grad.addColorStop(1,    'rgba(212,43,43,0.00)');

    /* Only show tick labels every 5 days to avoid crowding on mobile */
    const tickLabels = dailyLabels.map((l, i) => (i % 5 === 0 ? l : ''));

    new Chart(ctx, {
      type: 'line',
      data: {
        labels: dailyLabels,
        datasets: [{
          label:                'Likes',
          data:                 dailyData,
          borderColor:          RED,
          backgroundColor:      grad,
          borderWidth:          2,
          fill:                 true,
          tension:              0.35,
          /* Points: visible only on days with >0 likes */
          pointRadius:          dailyData.map(v => v > 0 ? 4 : 0),
          pointHoverRadius:     6,
          pointBackgroundColor: '#fff',
          pointBorderColor:     RED,
          pointBorderWidth:     2,
          pointHoverBackgroundColor: RED,
        }]
      },
      options: {
        responsive:          true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1a1a1a',
            titleColor:      '#fff',
            bodyColor:       'rgba(255,255,255,0.75)',
            padding:         12,
            cornerRadius:    8,
            displayColors:   false,
            callbacks: {
              title: items => items[0].label,
              label: ctx  => '  ' + ctx.parsed.y + ' like' + (ctx.parsed.y !== 1 ? 's' : ''),
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              stepSize:  1,
              precision: 0,
              padding:   8,
            },
            grid:   { color: GRID_CLR, drawBorder: false },
            border: { display: false },
          },
          x: {
            ticks: {
              padding:  8,
              maxRotation: 0,
              /* Show only every-5th label */
              callback: function(val, i) { return tickLabels[i]; }
            },
            grid:   { display: false },
            border: { display: false },
          }
        }
      }
    });
  }

  /* ── 5. KPI counter animation ────────────────────────────────────────
     Counts each number from 0 to its target value over 900ms.
     Uses a cubic ease-out so it decelerates near the end.
  ────────────────────────────────────────────────────────────────────── */
  function animateCounter(el) {
    const target   = parseInt(el.dataset.target, 10) || 0;
    if (target === 0) { el.textContent = '0'; return; }
    const duration = 900;
    const start    = performance.now();

    (function step(now) {
      const progress = Math.min((now - start) / duration, 1);
      const eased    = 1 - Math.pow(1 - progress, 3); /* cubic ease-out */
      el.textContent = Math.round(eased * target).toLocaleString('en-IN');
      if (progress < 1) requestAnimationFrame(step);
    })(start);
  }

  document.querySelectorAll('.ws-kpi-num[data-target]').forEach(animateCounter);

  /* ── 6. Staggered row reveal on scroll ──────────────────────────────
     IntersectionObserver watches table rows and activity items.
     When they scroll into view, the 'visible' class triggers a CSS
     fade-up animation. Each item is delayed by its index × 40ms.
  ────────────────────────────────────────────────────────────────────── */
  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('ws-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.ws-tr, .ws-activity-item, .ws-kpi').forEach(function(el, i) {
    el.style.transitionDelay = (i * 40) + 'ms';
    observer.observe(el);
  });

})();
</script>


