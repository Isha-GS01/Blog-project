# knowledge_base/serializers.py
# WHY serializers: When Django returns a Post object, it's a Python object.
# The outside world (mobile apps, other services) speak JSON.
# Serializers handle the conversion cleanly and safely —
# you control exactly which fields are exposed.

from rest_framework import serializers
from .models import Post, Comment, Category, ActUser


# ─────────────────────────────────────────────────────
# AUTHOR SERIALIZER (nested — used inside PostSerializer)
# WHY: We never expose sensitive fields like password hashes.
# We pick exactly what's safe to share publicly.
# ─────────────────────────────────────────────────────
class AuthorSerializer(serializers.ModelSerializer):
    full_name = serializers.SerializerMethodField()

    class Meta:
        model  = ActUser
        fields = ('id', 'full_name', 'department', 'avatar')

    def get_full_name(self, obj):
        return obj.get_full_name()


# ─────────────────────────────────────────────────────
# CATEGORY SERIALIZER
# ─────────────────────────────────────────────────────
class CategorySerializer(serializers.ModelSerializer):
    class Meta:
        model  = Category
        fields = ('id', 'name', 'slug')


# ─────────────────────────────────────────────────────
# COMMENT SERIALIZER
# ─────────────────────────────────────────────────────
class CommentSerializer(serializers.ModelSerializer):
    author = AuthorSerializer(read_only=True)

    class Meta:
        model  = Comment
        fields = ('id', 'author', 'body', 'created_at')


# ─────────────────────────────────────────────────────
# POST LIST SERIALIZER (lightweight — for list views)
# WHY two serializers for Post: The list view shows many posts,
# so we keep it lean (no full body text, no comments).
# The detail view shows one post, so we include everything.
# ─────────────────────────────────────────────────────
class PostListSerializer(serializers.ModelSerializer):
    author    = AuthorSerializer(read_only=True)
    category  = CategorySerializer(read_only=True)
    tags      = serializers.SerializerMethodField()
    upvote_count  = serializers.IntegerField(read_only=True)
    comment_count = serializers.IntegerField(read_only=True)
    # SerializerMethodField: call a custom method to compute this value
    excerpt   = serializers.SerializerMethodField()

    class Meta:
        model  = Post
        fields = (
            'id', 'title', 'slug', 'author', 'category',
            'tags', 'excerpt', 'ai_summary',
            'upvote_count', 'comment_count',
            'published_at', 'created_at',
        )

    def get_tags(self, obj):
        # django-taggit stores tags in a special manager — we convert to a plain list
        return list(obj.tags.names())

    def get_excerpt(self, obj):
        # First 300 characters of the body as a preview
        return obj.body[:300] + '...' if len(obj.body) > 300 else obj.body


# ─────────────────────────────────────────────────────
# POST DETAIL SERIALIZER (full — for single post view)
# ─────────────────────────────────────────────────────
class PostDetailSerializer(PostListSerializer):
    comments = serializers.SerializerMethodField()

    class Meta(PostListSerializer.Meta):
        fields = PostListSerializer.Meta.fields + ('body', 'comments', 'updated_at')

    def get_comments(self, obj):
        # Only return approved comments
        approved = obj.comments.filter(is_approved=True)
        return CommentSerializer(approved, many=True).data


# ─────────────────────────────────────────────────────
# TOP AUTHOR SERIALIZER (for analytics endpoint)
# ─────────────────────────────────────────────────────
class TopAuthorSerializer(serializers.ModelSerializer):
    full_name   = serializers.SerializerMethodField()
    post_count  = serializers.IntegerField(read_only=True)  # Annotated in the view

    class Meta:
        model  = ActUser
        fields = ('id', 'full_name', 'department', 'avatar', 'post_count')

    def get_full_name(self, obj):
        return obj.get_full_name()
</file>

<file path="knowledge_base/templates/knowledge_base/analytics_dashboard.html">
{% extends "knowledge_base/base.html" %}
{% load static %}

{% block title %}Analytics — ACT InnerCircle{% endblock %}

{% block content %}

{# ═══════════════════════════════════════════════════════════════
   DATA BRIDGE — Pass Django context variables to JavaScript safely.

   json_script renders a <script type="application/json"> tag.
   JavaScript then reads it with JSON.parse(document.getElementById(...).textContent)
   This avoids XSS vulnerabilities that arise from directly
   interpolating Python values into JS strings like:
       var data = {{ author_data }};   ← UNSAFE, never do this
   ═══════════════════════════════════════════════════════════════ #}
{{ author_labels|json_script:"js-author-labels" }}
{{ author_data|json_script:"js-author-data" }}
{{ trend_labels|json_script:"js-trend-labels" }}
{{ trend_data|json_script:"js-trend-data" }}


<div class="an-page">

  <!-- ── Page header ──────────────────────────────────────── -->
  <header class="an-header">
    <div class="an-header-text">
      <p class="an-header-eyebrow">ACT InnerCircle</p>
      <h1 class="an-header-title">Platform Analytics</h1>
    </div>
    <div class="an-header-meta">
      <span class="an-live-dot"></span>
      <span class="an-live-label">Live data</span>
      <span class="an-header-date">{{ now|date:"d M Y" }}</span>
    </div>
  </header>

  <!-- ── KPI summary strip ────────────────────────────────── -->
  <section class="an-kpi-strip" aria-label="Key metrics">
    <div class="an-kpi-card an-kpi-card--accent">
      <span class="an-kpi-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
          <path d="M14 2v6h6M8 13h8M8 17h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="an-kpi-num" data-target="{{ total_posts }}">0</span>
      <span class="an-kpi-label">Published Posts</span>
    </div>

    <div class="an-kpi-card">
      <span class="an-kpi-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.6"/>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="an-kpi-num" data-target="{{ total_authors }}">0</span>
      <span class="an-kpi-label">Active Employees</span>
    </div>

    <div class="an-kpi-card">
      <span class="an-kpi-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M12 4l2.09 6.26L20 12l-5.91 1.74L12 20l-2.09-6.26L4 12l5.91-1.74L12 4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="an-kpi-num" data-target="{{ total_upvotes }}">0</span>
      <span class="an-kpi-label">Total Upvotes</span>
    </div>

    <div class="an-kpi-card">
      <span class="an-kpi-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="an-kpi-num" data-target="{{ total_comments|default:0 }}">0</span>
      <span class="an-kpi-label">Comments</span>
    </div>
  </section>

  <!-- ── Charts row ───────────────────────────────────────── -->
  <section class="an-charts-row" aria-label="Charts">

    <!-- Line chart: post trend -->
    <div class="an-chart-card an-chart-card--wide">
      <div class="an-chart-header">
        <div>
          <h2 class="an-chart-title">Publishing Trend</h2>
          <p class="an-chart-sub">Posts published per month — last 6 months</p>
        </div>
        <div class="an-chart-legend">
          <span class="an-legend-dot an-legend-dot--red"></span>
          <span class="an-legend-text">Published posts</span>
        </div>
      </div>
      <div class="an-chart-body">
        <canvas id="trendChart"></canvas>
      </div>
    </div>

    <!-- Bar chart: top authors -->
    <div class="an-chart-card">
      <div class="an-chart-header">
        <div>
          <h2 class="an-chart-title">Top Authors</h2>
          <p class="an-chart-sub">By published post count</p>
        </div>
      </div>
      <div class="an-chart-body">
        <canvas id="authorChart"></canvas>
      </div>
    </div>

  </section>

  <!-- ── Bottom tables row ────────────────────────────────── -->
  <section class="an-tables-row" aria-label="Top posts">

    <!-- Most liked — all time -->
    <div class="an-table-card">
      <div class="an-table-header">
        <h2 class="an-table-title">Most Liked — All Time</h2>
        <span class="an-table-badge an-table-badge--alltime">All time</span>
      </div>
      <table class="an-table">
        <thead>
          <tr>
            <th class="an-th-rank"></th>
            <th>Post</th>
            <th>Author</th>
            <th class="an-th-num">Likes</th>
          </tr>
        </thead>
        <tbody>
          {% for post in top_posts_alltime %}
          <tr class="an-tr">
            <td class="an-td-rank">
              {% if forloop.counter == 1 %}<span class="an-medal an-medal--gold">1</span>
              {% elif forloop.counter == 2 %}<span class="an-medal an-medal--silver">2</span>
              {% elif forloop.counter == 3 %}<span class="an-medal an-medal--bronze">3</span>
              {% else %}<span class="an-rank-plain">{{ forloop.counter }}</span>
              {% endif %}
            </td>
            <td class="an-td-post">
              <a href="{% url 'post_detail' post.slug %}" class="an-post-link">{{ post.title }}</a>
              {% if post.category %}
                <span class="an-chip">{{ post.category.name }}</span>
              {% endif %}
            </td>
            <td class="an-td-author">
              <div class="an-author-cell">
                <div class="an-avatar">{{ post.author.first_name|first|default:post.author.email|first|upper }}</div>
                <span>{{ post.author.get_full_name|default:post.author.email|truncatechars:20 }}</span>
              </div>
            </td>
            <td class="an-td-num">
              <div class="an-like-bar-wrap">
                <span class="an-like-count">{{ post.upvote_count }}</span>
                <div class="an-like-track">
                  <div class="an-like-fill" style="width: {% widthratio post.upvote_count top_posts_alltime.0.upvote_count 100 %}%"></div>
                </div>
              </div>
            </td>
          </tr>
          {% empty %}
          <tr><td colspan="4" class="an-empty">No published posts yet.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <!-- Most liked — this month -->
    <div class="an-table-card">
      <div class="an-table-header">
        <h2 class="an-table-title">Most Liked — This Month</h2>
        <span class="an-table-badge an-table-badge--month">{{ now|date:"M Y" }}</span>
      </div>
      <table class="an-table">
        <thead>
          <tr>
            <th class="an-th-rank"></th>
            <th>Post</th>
            <th>Author</th>
            <th class="an-th-num">Likes</th>
          </tr>
        </thead>
        <tbody>
          {% for post in top_posts_monthly %}
          <tr class="an-tr">
            <td class="an-td-rank">
              {% if forloop.counter == 1 %}<span class="an-medal an-medal--gold">1</span>
              {% elif forloop.counter == 2 %}<span class="an-medal an-medal--silver">2</span>
              {% elif forloop.counter == 3 %}<span class="an-medal an-medal--bronze">3</span>
              {% else %}<span class="an-rank-plain">{{ forloop.counter }}</span>
              {% endif %}
            </td>
            <td class="an-td-post">
              <a href="{% url 'post_detail' post.slug %}" class="an-post-link">{{ post.title }}</a>
            </td>
            <td class="an-td-author">
              <div class="an-author-cell">
                <div class="an-avatar">{{ post.author.first_name|first|default:post.author.email|first|upper }}</div>
                <span>{{ post.author.get_full_name|default:post.author.email|truncatechars:20 }}</span>
              </div>
            </td>
            <td class="an-td-num">
              <div class="an-like-bar-wrap">
                <span class="an-like-count">{{ post.upvote_count }}</span>
                <div class="an-like-track">
                  <div class="an-like-fill" style="width: {% if top_posts_monthly.0.upvote_count > 0 %}{% widthratio post.upvote_count top_posts_monthly.0.upvote_count 100 %}{% else %}0{% endif %}%"></div>
                </div>
              </div>
            </td>
          </tr>
          {% empty %}
          <tr><td colspan="4" class="an-empty">No posts published this month yet.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

  </section>

  <!-- ── Top authors leaderboard ──────────────────────────── -->
  <section class="an-authors-section" aria-label="Top authors leaderboard">
    <div class="an-table-card an-table-card--full">
      <div class="an-table-header">
        <h2 class="an-table-title">Author Leaderboard</h2>
        <span class="an-table-badge an-table-badge--alltime">Top contributors</span>
      </div>
      <div class="an-leaderboard">
        {% for author in top_authors %}
        <div class="an-lb-row {% if forloop.counter == 1 %}an-lb-row--top{% endif %}">
          <div class="an-lb-rank">
            {% if forloop.counter == 1 %}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6L12 2z"/></svg>
            {% else %}
              <span class="an-lb-num">{{ forloop.counter }}</span>
            {% endif %}
          </div>
          <div class="an-lb-avatar">{{ author.first_name|first|default:author.email|first|upper }}</div>
          <div class="an-lb-info">
            <span class="an-lb-name">{{ author.get_full_name|default:author.email }}</span>
            <span class="an-lb-dept">{{ author.department|default:"ACT Fibernet" }}</span>
          </div>
          <div class="an-lb-bar-wrap">
            <div class="an-lb-track">
              <div class="an-lb-fill" style="width: {% widthratio author.post_count top_authors.0.post_count 100 %}%"></div>
            </div>
          </div>
          <div class="an-lb-count">
            <span class="an-lb-num-big">{{ author.post_count }}</span>
            <span class="an-lb-unit">posts</span>
          </div>
        </div>
        {% empty %}
        <p class="an-empty">No authors yet.</p>
        {% endfor %}
      </div>
    </div>
  </section>

</div><!-- /an-page -->


<!-- Chart.js from CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
(function () {
  'use strict';

  /* ── 1. Read Django data from json_script tags ──────────────────────
     This is the SAFE pattern. Never do: var x = {{ variable }}
     json_script escapes HTML entities, preventing XSS attacks.
  ──────────────────────────────────────────────────────────────────── */
  const authorLabels = JSON.parse(document.getElementById('js-author-labels').textContent);
  const authorData   = JSON.parse(document.getElementById('js-author-data').textContent);
  const trendLabels  = JSON.parse(document.getElementById('js-trend-labels').textContent);
  const trendData    = JSON.parse(document.getElementById('js-trend-data').textContent);

  /* ── 2. Design tokens — kept in one place ── */
  const RED        = '#D42B2B';
  const RED_PALE   = 'rgba(212,43,43,0.08)';
  const RED_MID    = 'rgba(212,43,43,0.18)';
  const INK_LIGHT  = 'rgba(26,26,26,0.06)';
  const TEXT_MUTED = '#999';
  const FONT       = "'DM Sans', system-ui, sans-serif";

  Chart.defaults.font.family = FONT;
  Chart.defaults.font.size   = 12;
  Chart.defaults.color       = TEXT_MUTED;

  /* ── 3. Line chart — Publishing Trend ─────────────────────────────── */
  const trendCtx = document.getElementById('trendChart').getContext('2d');

  /* Gradient fill under the line */
  const trendGrad = trendCtx.createLinearGradient(0, 0, 0, 260);
  trendGrad.addColorStop(0,   'rgba(212,43,43,0.15)');
  trendGrad.addColorStop(0.7, 'rgba(212,43,43,0.03)');
  trendGrad.addColorStop(1,   'rgba(212,43,43,0.00)');

  new Chart(trendCtx, {
    type: 'line',
    data: {
      labels: trendLabels,
      datasets: [{
        label: 'Posts published',
        data: trendData,
        borderColor: RED,
        backgroundColor: trendGrad,
        borderWidth: 2.5,
        pointBackgroundColor: '#fff',
        pointBorderColor: RED,
        pointBorderWidth: 2,
        pointRadius: 5,
        pointHoverRadius: 7,
        pointHoverBackgroundColor: RED,
        fill: true,
        tension: 0.4,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#1a1a1a',
          titleColor: '#fff',
          bodyColor: 'rgba(255,255,255,0.75)',
          padding: 12,
          cornerRadius: 8,
          callbacks: {
            title: items => items[0].label,
            label: ctx  => '  ' + ctx.parsed.y + ' post' + (ctx.parsed.y !== 1 ? 's' : ''),
          }
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            stepSize: 1,
            precision: 0,
            padding: 8,
          },
          grid: { color: INK_LIGHT, drawBorder: false },
          border: { display: false },
        },
        x: {
          grid: { display: false },
          border: { display: false },
          ticks: { padding: 8 },
        }
      }
    }
  });

  /* ── 4. Bar chart — Top Authors ──────────────────────────────────── */
  /* Build bar colors: first bar = solid red, rest = progressively lighter */
  const barColors  = authorData.map((_, i) => i === 0 ? RED : `rgba(212,43,43,${0.20 - i * 0.03})`);
  const barBorders = authorData.map((_, i) => i === 0 ? RED : `rgba(212,43,43,0.35)`);

  new Chart(document.getElementById('authorChart'), {
    type: 'bar',
    data: {
      labels: authorLabels,
      datasets: [{
        label: 'Posts',
        data: authorData,
        backgroundColor: barColors,
        borderColor: barBorders,
        borderWidth: 1,
        borderRadius: 6,
        borderSkipped: false,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#1a1a1a',
          titleColor: '#fff',
          bodyColor: 'rgba(255,255,255,0.75)',
          padding: 12,
          cornerRadius: 8,
          callbacks: {
            label: ctx => '  ' + ctx.parsed.y + ' post' + (ctx.parsed.y !== 1 ? 's' : ''),
          }
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: { stepSize: 1, precision: 0, padding: 8 },
          grid: { color: INK_LIGHT, drawBorder: false },
          border: { display: false },
        },
        x: {
          grid: { display: false },
          border: { display: false },
          ticks: {
            padding: 8,
            /* Truncate long names so they don't overlap */
            callback: function(val) {
              const label = this.getLabelForValue(val);
              return label.length > 12 ? label.slice(0, 11) + '…' : label;
            }
          },
        }
      }
    }
  });

  /* ── 5. KPI counter animation ────────────────────────────────────── */
  /* Animates numbers from 0 up to their target on page load */
  function animateCounter(el) {
    const target   = parseInt(el.dataset.target, 10) || 0;
    const duration = 1000;
    const start    = performance.now();

    function step(now) {
      const elapsed  = now - start;
      const progress = Math.min(elapsed / duration, 1);
      /* Ease-out cubic: slows down as it approaches target */
      const eased    = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(eased * target).toLocaleString('en-IN');
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  document.querySelectorAll('.an-kpi-num[data-target]').forEach(animateCounter);

  /* ── 6. Progress bar animation ───────────────────────────────────── */
  /* Stagger-animate the leaderboard bars and like-fill bars on load */
  const fills = document.querySelectorAll('.an-lb-fill, .an-like-fill');
  fills.forEach(function(el, i) {
    const targetW = el.style.width;
    el.style.width = '0';
    setTimeout(function() {
      el.style.transition = 'width 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      el.style.width = targetW;
    }, 200 + i * 60);
  });

})();
</script>


<style>
/* ═══════════════════════════════════════════════════════
   ACT InnerCircle — Analytics Dashboard
   Fonts: DM Serif Display (display) + DM Sans (body)
   Primary: #D42B2B
═══════════════════════════════════════════════════════ */

.an-page {
  max-width: 1120px;
  margin: 0 auto;
  padding: 2rem 1.5rem 5rem;
  font-family: 'DM Sans', system-ui, sans-serif;
}

/* ── Header ── */
.an-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 2.25rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid #ebe8e2;
}
.an-header-eyebrow {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: #D42B2B;
  margin: 0 0 4px;
}
.an-header-title {
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: 2rem;
  font-weight: 400;
  color: #1a1a1a;
  margin: 0;
  line-height: 1.1;
}
.an-header-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: #aaa;
}
.an-live-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #22c55e;
  box-shadow: 0 0 0 3px rgba(34,197,94,0.20);
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 3px rgba(34,197,94,0.20); }
  50%       { box-shadow: 0 0 0 6px rgba(34,197,94,0.08); }
}
.an-live-label { color: #22c55e; font-weight: 500; }
.an-header-date { color: #bbb; }

/* ── KPI strip ── */
.an-kpi-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
  margin-bottom: 1.5rem;
}
@media (max-width: 760px) { .an-kpi-strip { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 420px) { .an-kpi-strip { grid-template-columns: 1fr; } }

.an-kpi-card {
  background: #fff;
  border: 1px solid #ebe8e2;
  border-radius: 12px;
  padding: 1.25rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 6px;
  position: relative;
  overflow: hidden;
  transition: box-shadow .2s, transform .2s;
}
.an-kpi-card:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,.07);
  transform: translateY(-2px);
}
.an-kpi-card--accent {
  border-color: #f5c0c0;
  background: #fdf5f5;
}
.an-kpi-card--accent::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: #D42B2B;
  border-radius: 12px 12px 0 0;
}
.an-kpi-icon {
  color: #D42B2B;
  display: flex;
  align-items: center;
  margin-bottom: 2px;
}
.an-kpi-card:not(.an-kpi-card--accent) .an-kpi-icon { color: #bbb; }
.an-kpi-num {
  font-size: 2rem;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}
.an-kpi-card--accent .an-kpi-num { color: #D42B2B; }
.an-kpi-label {
  font-size: 11px;
  color: #aaa;
  text-transform: uppercase;
  letter-spacing: .07em;
  font-weight: 500;
}

/* ── Charts row ── */
.an-charts-row {
  display: grid;
  grid-template-columns: 1.6fr 1fr;
  gap: 1.25rem;
  margin-bottom: 1.5rem;
}
@media (max-width: 820px) { .an-charts-row { grid-template-columns: 1fr; } }

.an-chart-card {
  background: #fff;
  border: 1px solid #ebe8e2;
  border-radius: 12px;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
}
.an-chart-card--wide { /* inherits, no extra needed */ }

.an-chart-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 1.25rem;
  gap: 1rem;
}
.an-chart-title {
  font-size: 14px;
  font-weight: 600;
  color: #1a1a1a;
  margin: 0 0 3px;
}
.an-chart-sub {
  font-size: 12px;
  color: #aaa;
  margin: 0;
}
.an-chart-legend {
  display: flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
}
.an-legend-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.an-legend-dot--red { background: #D42B2B; }
.an-legend-text { font-size: 11px; color: #aaa; }

.an-chart-body {
  flex: 1;
  position: relative;
  min-height: 220px;
}

/* ── Tables row ── */
.an-tables-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
  margin-bottom: 1.5rem;
}
@media (max-width: 820px) { .an-tables-row { grid-template-columns: 1fr; } }

.an-table-card {
  background: #fff;
  border: 1px solid #ebe8e2;
  border-radius: 12px;
  overflow: hidden;
}
.an-table-card--full { width: 100%; }

.an-table-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.1rem 1.4rem;
  border-bottom: 1px solid #f2efea;
  background: #faf9f7;
}
.an-table-title {
  font-size: 13px;
  font-weight: 600;
  color: #1a1a1a;
  margin: 0;
}
.an-table-badge {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: .05em;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 20px;
}
.an-table-badge--alltime { background: #fdf1f1; color: #9b1c1c; border: 1px solid #f5c0c0; }
.an-table-badge--month   { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }

/* Table internals */
.an-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}
.an-table thead th {
  padding: 8px 14px;
  font-size: 10px;
  font-weight: 600;
  color: #bbb;
  text-transform: uppercase;
  letter-spacing: .07em;
  text-align: left;
  background: #faf9f7;
  border-bottom: 1px solid #f2efea;
}
.an-th-rank { width: 36px; }
.an-th-num  { text-align: right; }

.an-tr td { padding: 10px 14px; border-bottom: 1px solid #f7f5f2; vertical-align: middle; }
.an-tr:last-child td { border-bottom: none; }
.an-tr:hover td { background: #fdf9f9; }

.an-td-rank { width: 36px; }
.an-td-post { max-width: 0; }  /* forces text-overflow on narrow screens */
.an-td-author { white-space: nowrap; }
.an-td-num  { text-align: right; }

.an-medal {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 22px; height: 22px;
  border-radius: 50%;
  font-size: 10px;
  font-weight: 700;
}
.an-medal--gold   { background: #fef3c7; color: #92400e; border: 1px solid #fde68a; }
.an-medal--silver { background: #f1f5f9; color: #475569; border: 1px solid #cbd5e1; }
.an-medal--bronze { background: #fff7ed; color: #9a3412; border: 1px solid #fed7aa; }
.an-rank-plain    { font-size: 12px; color: #ccc; font-weight: 600; padding-left: 5px; }

.an-post-link {
  color: #1a1a1a;
  text-decoration: none;
  font-weight: 500;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 200px;
}
.an-post-link:hover { color: #D42B2B; text-decoration: underline; }

.an-chip {
  display: inline-block;
  font-size: 10px;
  background: #f2f0ec;
  color: #777;
  padding: 1px 8px;
  border-radius: 20px;
  margin-top: 3px;
  font-weight: 500;
}
.an-author-cell {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #666;
}
.an-avatar {
  width: 26px; height: 26px;
  border-radius: 50%;
  background: #fdf1f1;
  color: #D42B2B;
  font-size: 11px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 1px solid #f5c0c0;
}

/* Mini like bar */
.an-like-bar-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  justify-content: flex-end;
}
.an-like-count {
  font-weight: 600;
  color: #D42B2B;
  font-size: 13px;
  min-width: 20px;
  text-align: right;
}
.an-like-track {
  width: 60px; height: 4px;
  background: #f2efea;
  border-radius: 2px;
  overflow: hidden;
}
.an-like-fill {
  height: 100%;
  background: #D42B2B;
  border-radius: 2px;
  width: 0; /* animated by JS */
}

/* ── Author leaderboard ── */
.an-authors-section { margin-top: 0; }

.an-leaderboard {
  padding: 0.75rem 0;
}
.an-lb-row {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px 1.4rem;
  border-bottom: 1px solid #f7f5f2;
  transition: background .15s;
}
.an-lb-row:last-child { border-bottom: none; }
.an-lb-row:hover { background: #fdf9f9; }
.an-lb-row--top { background: #fdf5f5; }
.an-lb-row--top:hover { background: #fceaea; }

.an-lb-rank {
  width: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.an-lb-num { font-size: 12px; color: #ccc; font-weight: 700; }

.an-lb-avatar {
  width: 34px; height: 34px;
  border-radius: 50%;
  background: #fdf1f1;
  color: #D42B2B;
  font-size: 13px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 1px solid #f5c0c0;
}
.an-lb-row--top .an-lb-avatar {
  background: #D42B2B;
  color: #fff;
  border-color: #D42B2B;
}

.an-lb-info {
  display: flex;
  flex-direction: column;
  gap: 1px;
  min-width: 140px;
  flex-shrink: 0;
}
.an-lb-name { font-size: 13px; font-weight: 600; color: #1a1a1a; }
.an-lb-dept { font-size: 11px; color: #aaa; }

.an-lb-bar-wrap { flex: 1; min-width: 80px; }
.an-lb-track {
  height: 5px;
  background: #f2efea;
  border-radius: 3px;
  overflow: hidden;
}
.an-lb-fill {
  height: 100%;
  background: #D42B2B;
  border-radius: 3px;
  width: 0; /* animated by JS */
}
.an-lb-row--top .an-lb-fill { background: #D42B2B; }

.an-lb-count {
  display: flex;
  align-items: baseline;
  gap: 3px;
  flex-shrink: 0;
  min-width: 60px;
  justify-content: flex-end;
}
.an-lb-num-big { font-size: 18px; font-weight: 700; color: #D42B2B; }
.an-lb-unit    { font-size: 11px; color: #bbb; }

/* Empty state */
.an-empty {
  text-align: center;
  padding: 2.5rem 1rem;
  color: #ccc;
  font-style: italic;
  font-size: 13px;
}

/* Responsive table scroll on small screens */
@media (max-width: 560px) {
  .an-table-card { overflow-x: auto; }
  .an-post-link  { max-width: 140px; }
}
</style>

{% endblock %}
</file>

<file path="knowledge_base/templates/knowledge_base/approval_queue.html">
{% extends "knowledge_base/base.html" %}
{% block title %}Approval Queue — ACT InnerCircle{% endblock %}
{% block nav_queue %}active{% endblock %}

{% block right_sidebar %}
<div class="widget">
  <div class="widget-title">📋 Queue Info</div>
  <div style="text-align:center;padding:16px 0;">
    <div style="font-size:42px;font-weight:700;color:var(--red);">{{ pending_posts.count }}</div>
    <div style="font-size:13px;color:var(--ink-4);margin-top:4px;">Articles awaiting review</div>
  </div>
  <div style="font-size:13px;color:var(--ink-3);background:var(--bg);border-radius:var(--radius-md);padding:12px;line-height:1.6;">
    Review each post carefully. Approved posts are published instantly and visible to all employees.
  </div>
</div>

<div class="widget">
  <div class="widget-title">⚡ Quick Actions</div>
  <div style="display:flex;flex-direction:column;gap:8px;">
    <a href="{% url 'knowledge_base:post_list' %}" class="btn btn-secondary btn-sm" style="justify-content:center;">View Published Posts</a>
    <a href="/admin/knowledge_base/post/" class="btn btn-secondary btn-sm" style="justify-content:center;">Manage in Admin Panel</a>
  </div>
</div>
{% endblock %}

{% block content %}
<div class="section-header">
  <div>
    <h1 class="section-title">Approval Queue</h1>
    <p class="section-subtitle">Review and approve articles submitted by employees</p>
  </div>
  {% if pending_posts %}
  <span class="badge badge-pending" style="font-size:14px;padding:6px 14px;">
    {{ pending_posts.count }} pending
  </span>
  {% endif %}
</div>

{% for post in pending_posts %}
<div class="card" style="margin-bottom:20px;overflow:hidden;">

  <!-- Post header -->
  <div style="padding:24px 24px 16px;">
    <!-- Author + meta -->
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
      <div class="post-author-avatar" style="width:40px;height:40px;font-size:15px;">
        {% if post.author.avatar %}<img src="{{ post.author.avatar.url }}" alt="">
        {% else %}{{ post.author.first_name|first|upper }}{% endif %}
      </div>
      <div>
        <div style="font-weight:600;font-size:14px;">{{ post.author.get_full_name }}</div>
        <div style="font-size:12px;color:var(--ink-4);">{{ post.author.department|default:"ACT Fibernet" }} · Submitted {{ post.updated_at|date:"d M, Y" }}</div>
      </div>
      <span class="badge badge-pending" style="margin-left:auto;">⏳ Pending Review</span>
    </div>

    <h2 style="font-size:19px;font-weight:600;margin-bottom:8px;line-height:1.35;">{{ post.title }}</h2>

    {% if post.category %}
    <span class="badge badge-blue" style="margin-bottom:12px;">{{ post.category.name }}</span>
    {% endif %}

    <!-- Excerpt -->
    <p style="font-size:14px;color:var(--ink-3);line-height:1.65;margin-bottom:16px;">
      {{ post.body|truncatewords:70 }}
    </p>

    <!-- AI Summary area -->
    <div id="ai-area-{{ post.slug }}">
      {% if post.ai_summary %}
      <div class="ai-box">
        <div class="ai-icon">🤖</div>
        <div>
          <div class="ai-label">AI Summary</div>
          <div class="ai-text">{{ post.ai_summary }}</div>
        </div>
      </div>
      {% else %}
      <button onclick="generateSummary('{{ post.slug }}', this)"
              style="display:flex;align-items:center;gap:8px;background:linear-gradient(135deg,#FFF8F0,#FFF0F5);
                     border:1px dashed #F4C5C5;color:var(--red);padding:10px 16px;
                     border-radius:var(--radius-md);cursor:pointer;font-size:13.5px;font-weight:500;
                     transition:all .2s;" id="ai-btn-{{ post.slug }}">
        🤖 Generate AI Summary
      </button>
      {% endif %}
    </div>
  </div>

  <!-- Action bar -->
  <div style="padding:16px 24px;background:var(--bg);border-top:1px solid var(--border);
              display:flex;align-items:center;gap:10px;flex-wrap:wrap;">

    <!-- Approve -->
    <form method="post" action="{% url 'knowledge_base:post_approve' post.slug %}">
      {% csrf_token %}
      <button type="submit" class="btn btn-success">✅ Approve & Publish</button>
    </form>

    <!-- Reject with reason -->
    <form method="post" action="{% url 'knowledge_base:post_reject' post.slug %}"
          style="display:flex;gap:8px;align-items:center;flex:1;min-width:280px;">
      {% csrf_token %}
      <input name="reason" placeholder="Reason for rejection (optional)…"
             class="form-control" style="flex:1;padding:9px 14px;">
      <button type="submit" class="btn btn-secondary" style="border-color:var(--red);color:var(--red);">
        ✕ Reject
      </button>
    </form>

  </div>
</div>
{% empty %}
<div class="card">
  <div class="empty-state">
    <div class="empty-state-icon">🎉</div>
    <div class="empty-state-title">All caught up!</div>
    <div class="empty-state-text">There are no articles waiting for review. Check back later.</div>
  </div>
</div>
{% endfor %}
{% endblock %}

{% block extra_js %}
<script>
async function generateSummary(slug, btn) {
  btn.textContent = '⏳ Generating summary…';
  btn.disabled = true;
  btn.style.opacity = '.7';

  try {
    const resp = await fetch(`/api/posts/${slug}/generate-summary/`, {
      method: 'POST',
      headers: {
        'X-CSRFToken': document.cookie.match(/csrftoken=([^;]+)/)?.[1] || '',
        'Content-Type': 'application/json',
      },
    });
    const data = await resp.json();

    if (data.success) {
      const area = document.getElementById(`ai-area-${slug}`);
      area.innerHTML = `
        <div class="ai-box">
          <div class="ai-icon">🤖</div>
          <div>
            <div class="ai-label">AI Summary</div>
            <div class="ai-text">${data.ai_summary}</div>
          </div>
        </div>`;
    } else {
      btn.textContent = '❌ Failed — try again';
      btn.disabled = false; btn.style.opacity = '1';
    }
  } catch {
    btn.textContent = '❌ Error — try again';
    btn.disabled = false; btn.style.opacity = '1';
  }
}
</script>
{% endblock %}
</file>

<file path="knowledge_base/templates/knowledge_base/auth/login.html">
{% extends "knowledge_base/base.html" %}
{% block title %}Sign In — ACT InnerCircle{% endblock %}

{% block extra_head %}
<style>
  /* Hide sidebars on auth pages */
  .sidebar-left, .sidebar-right { display: none !important; }
  .main-content { margin-left: 0 !important; margin-right: 0 !important; }
  .auth-wrap {
    min-height: calc(100vh - var(--nav-h));
    display: flex; align-items: center; justify-content: center;
    padding: 40px 16px;
    background: linear-gradient(135deg, #FFF5F5 0%, #F4F5F7 60%, #F0F4FF 100%);
  }
  .auth-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    padding: 40px;
    width: 100%; max-width: 420px;
    animation: fadeSlide .35s ease;
  }
</style>
{% endblock %}

{% block content %}
<div class="auth-wrap">
  <div class="auth-card">

    <!-- Logo -->
    <div style="text-align:center;margin-bottom:28px;">
      <div style="width:52px;height:52px;border-radius:14px;background:var(--red);
                  display:flex;align-items:center;justify-content:center;
                  font-size:26px;margin:0 auto 14px;">⚡</div>
      <h1 style="font-size:22px;font-weight:700;letter-spacing:-.3px;margin-bottom:4px;">Welcome back</h1>
      <p style="font-size:14px;color:var(--ink-4);">Sign in to ACT InnerCircle</p>
    </div>

    <!-- Error -->
    {% if form.non_field_errors %}
    <div class="flash flash-error" style="margin-bottom:20px;">
      ✕ Invalid email or password. Please try again.
    </div>
    {% endif %}

    <form method="post">
      {% csrf_token %}

      <div class="form-group" style="margin-bottom:16px;">
        <label class="form-label">ACT Corporate Email</label>
        {{ form.username }}
      </div>

      <div class="form-group" style="margin-bottom:24px;">
        <label class="form-label">Password</label>
        {{ form.password }}
      </div>

      <button type="submit" class="btn btn-primary btn-lg" style="width:100%;justify-content:center;">
        Sign In →
      </button>
    </form>

    <p style="text-align:center;margin-top:20px;font-size:14px;color:var(--ink-4);">
      Don't have an account?
      <a href="{% url 'knowledge_base:register' %}" style="color:var(--red);font-weight:500;">Join InnerCircle</a>
    </p>

  </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
  // Style Django's raw input widgets
  document.querySelectorAll('input[type=text],input[type=email],input[type=password]').forEach(el => {
    el.classList.add('form-control');
    el.setAttribute('autocomplete', el.type === 'password' ? 'current-password' : 'email');
  });
  document.querySelector('input[type=email]') && (document.querySelector('input[type=email]').placeholder = 'yourname@actcorp.in');
  document.querySelector('input[type=password]') && (document.querySelector('input[type=password]').placeholder = 'Your password');
</script>
{% endblock %}
</file>

<file path="knowledge_base/templates/knowledge_base/auth/profile.html">
{% extends "knowledge_base/base.html" %}
{% block title %}My Profile — ACT InnerCircle{% endblock %}
{% block nav_profile %}active{% endblock %}

{% block right_sidebar %}
<div class="widget">
  <div class="widget-title">📊 Contribution Stats</div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
    <div style="background:var(--bg);border-radius:var(--radius-md);padding:14px;text-align:center;">
      <div style="font-size:26px;font-weight:700;color:var(--red);">{{ published_posts.count }}</div>
      <div style="font-size:11px;color:var(--ink-4);margin-top:2px;">Published</div>
    </div>
    <div style="background:var(--bg);border-radius:var(--radius-md);padding:14px;text-align:center;">
      <div style="font-size:26px;font-weight:700;color:var(--red);">
        {% with total=0 %}0{% endwith %}👍
      </div>
      <div style="font-size:11px;color:var(--ink-4);margin-top:2px;">Upvotes</div>
    </div>
  </div>
</div>

{% if published_posts %}
<div class="widget">
  <div class="widget-title">📄 My Published Posts</div>
  {% for post in published_posts %}
  <a href="{% url 'knowledge_base:post_detail' post.slug %}"
     style="display:block;padding:8px 0;border-bottom:1px solid var(--border);text-decoration:none;">
    <div style="font-size:13px;font-weight:500;color:var(--ink);line-height:1.4;margin-bottom:3px;">{{ post.title|truncatechars:50 }}</div>
    <div style="font-size:11.5px;color:var(--ink-4);">👍 {{ post.upvote_count }} · 💬 {{ post.comment_count }}</div>
  </a>
  {% endfor %}
</div>
{% endif %}
{% endblock %}

{% block content %}
<div class="section-header">
  <div>
    <h1 class="section-title">My Profile</h1>
    <p class="section-subtitle">Update your professional information and preferences</p>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 300px;gap:24px;align-items:start;">

  <!-- Edit form -->
  <div class="card" style="padding:32px;">
    <h2 style="font-size:17px;font-weight:600;margin-bottom:24px;">Edit Information</h2>
    <form method="post" enctype="multipart/form-data">
      {% csrf_token %}

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
        <div class="form-group">
          <label class="form-label">First Name</label>
          <input type="text" name="first_name" class="form-control" value="{{ form.first_name.value|default:request.user.first_name }}">
        </div>
        <div class="form-group">
          <label class="form-label">Last Name</label>
          <input type="text" name="last_name" class="form-control" value="{{ form.last_name.value|default:request.user.last_name }}">
        </div>
      </div>

      <div class="form-group" style="margin-bottom:16px;">
        <label class="form-label">Department</label>
        <input type="text" name="department" class="form-control"
               placeholder="e.g. Network Operations"
               value="{{ form.department.value|default:request.user.department }}">
      </div>

      <div class="form-group" style="margin-bottom:16px;">
        <label class="form-label">Bio</label>
        <textarea name="bio" rows="4" class="form-control"
                  placeholder="A short professional bio visible on your author profile…"
                  style="resize:vertical;">{{ form.bio.value|default:request.user.bio }}</textarea>
        <span class="form-hint">Max 500 characters. Shown on your author profile.</span>
      </div>

      <div class="form-group" style="margin-bottom:24px;">
        <label class="form-label">Profile Photo</label>
        {% if request.user.avatar %}
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px;">
          <img src="{{ request.user.avatar.url }}" style="width:48px;height:48px;border-radius:50%;object-fit:cover;border:2px solid var(--border);">
          <span style="font-size:13px;color:var(--ink-4);">Current photo — upload a new one to replace it</span>
        </div>
        {% endif %}
        <input type="file" name="avatar" accept="image/*" class="form-control" style="padding:8px;">
        <span class="form-hint">JPEG or PNG. Square images work best.</span>
      </div>

      <button type="submit" class="btn btn-primary">Save Changes</button>

    </form>
  </div>

  <!-- Account info (read-only) -->
  <div style="display:flex;flex-direction:column;gap:16px;">

    <!-- Avatar card -->
    <div class="card" style="padding:24px;text-align:center;">
      <div class="nav-avatar" style="width:72px;height:72px;font-size:28px;margin:0 auto 12px;">
        {% if request.user.avatar %}
          <img src="{{ request.user.avatar.url }}" alt="">
        {% else %}{{ request.user.first_name|first|upper }}{% endif %}
      </div>
      <div style="font-weight:700;font-size:17px;margin-bottom:3px;">{{ request.user.get_full_name }}</div>
      <div style="font-size:13px;color:var(--ink-4);margin-bottom:10px;">{{ request.user.email }}</div>
      <span class="badge {% if request.user.is_admin_user %}badge-red{% else %}badge-blue{% endif %}">
        {{ request.user.get_role_display }}
      </span>
    </div>

    <!-- Account details -->
    <div class="card" style="padding:20px;">
      <div style="font-size:12px;font-weight:600;letter-spacing:.7px;text-transform:uppercase;color:var(--ink-4);margin-bottom:14px;">Account Details</div>
      <div style="display:flex;flex-direction:column;gap:12px;font-size:13.5px;">
        <div>
          <div style="color:var(--ink-4);font-size:12px;margin-bottom:2px;">Email</div>
          <div style="color:var(--ink-2);font-weight:500;">{{ request.user.email }}</div>
        </div>
        <div>
          <div style="color:var(--ink-4);font-size:12px;margin-bottom:2px;">Role</div>
          <div style="color:var(--ink-2);font-weight:500;">{{ request.user.get_role_display }}</div>
        </div>
        <div>
          <div style="color:var(--ink-4);font-size:12px;margin-bottom:2px;">Member since</div>
          <div style="color:var(--ink-2);font-weight:500;">{{ request.user.date_joined|date:"d M Y" }}</div>
        </div>
        {% if request.user.department %}
        <div>
          <div style="color:var(--ink-4);font-size:12px;margin-bottom:2px;">Department</div>
          <div style="color:var(--ink-2);font-weight:500;">{{ request.user.department }}</div>
        </div>
        {% endif %}
      </div>
    </div>

    <!-- Quick links -->
    <div class="card" style="padding:16px;">
      <a href="{% url 'knowledge_base:dashboard' %}" class="btn btn-secondary" style="width:100%;justify-content:center;margin-bottom:8px;">My Dashboard</a>
      <a href="{% url 'knowledge_base:post_create' %}" class="btn btn-primary" style="width:100%;justify-content:center;">✦ Write a Post</a>
    </div>

  </div>
</div>
{% endblock %}
</file>

<file path="knowledge_base/templates/knowledge_base/auth/register.html">
{% extends "knowledge_base/base.html" %}
{% block title %}Join ACT InnerCircle{% endblock %}

{% block extra_head %}
<style>
  .sidebar-left, .sidebar-right { display: none !important; }
  .main-content { margin-left: 0 !important; margin-right: 0 !important; }
  .auth-wrap {
    min-height: calc(100vh - var(--nav-h));
    display: flex; align-items: center; justify-content: center;
    padding: 40px 16px;
    background: linear-gradient(135deg, #FFF5F5 0%, #F4F5F7 60%, #F0F4FF 100%);
  }
  .auth-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    padding: 40px;
    width: 100%; max-width: 480px;
    animation: fadeSlide .35s ease;
  }
</style>
{% endblock %}

{% block content %}
<div class="auth-wrap">
  <div class="auth-card">

    <!-- Logo -->
    <div style="text-align:center;margin-bottom:28px;">
      <div style="width:52px;height:52px;border-radius:14px;background:var(--red);
                  display:flex;align-items:center;justify-content:center;
                  font-size:26px;margin:0 auto 14px;">⚡</div>
      <h1 style="font-size:22px;font-weight:700;letter-spacing:-.3px;margin-bottom:4px;">Join InnerCircle</h1>
      <p style="font-size:14px;color:var(--ink-4);">Only <strong>@actcorp.in</strong> email addresses are accepted</p>
    </div>

    <!-- Non-field errors -->
    {% if form.non_field_errors %}
    <div class="flash flash-error" style="margin-bottom:16px;">
      ✕ {{ form.non_field_errors.0 }}
    </div>
    {% endif %}

    <form method="post">
      {% csrf_token %}

      <!-- Name row -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
        <div class="form-group">
          <label class="form-label">First Name <span class="req">*</span></label>
          <input type="text" name="first_name" required class="form-control" placeholder="Arjun"
                 value="{{ form.first_name.value|default:'' }}">
          {% if form.first_name.errors %}<span class="form-error">{{ form.first_name.errors.0 }}</span>{% endif %}
        </div>
        <div class="form-group">
          <label class="form-label">Last Name <span class="req">*</span></label>
          <input type="text" name="last_name" required class="form-control" placeholder="Sharma"
                 value="{{ form.last_name.value|default:'' }}">
          {% if form.last_name.errors %}<span class="form-error">{{ form.last_name.errors.0 }}</span>{% endif %}
        </div>
      </div>

      <div class="form-group" style="margin-bottom:16px;">
        <label class="form-label">ACT Corporate Email <span class="req">*</span></label>
        <input type="email" name="email" required class="form-control" placeholder="yourname@actcorp.in"
               value="{{ form.email.value|default:'' }}" autocomplete="email">
        {% if form.email.errors %}
          <span class="form-error">{{ form.email.errors.0 }}</span>
        {% endif %}
      </div>

      <div class="form-group" style="margin-bottom:16px;">
        <label class="form-label">Department</label>
        <input type="text" name="department" class="form-control" placeholder="e.g. Network Operations, Customer Experience"
               value="{{ form.department.value|default:'' }}">
      </div>

      <div class="form-group" style="margin-bottom:16px;">
        <label class="form-label">Password <span class="req">*</span></label>
        <input type="password" name="password1" required class="form-control" placeholder="Create a strong password" autocomplete="new-password">
        {% if form.password1.errors %}<span class="form-error">{{ form.password1.errors.0 }}</span>{% endif %}
      </div>

      <div class="form-group" style="margin-bottom:24px;">
        <label class="form-label">Confirm Password <span class="req">*</span></label>
        <input type="password" name="password2" required class="form-control" placeholder="Repeat your password" autocomplete="new-password">
        {% if form.password2.errors %}<span class="form-error">{{ form.password2.errors.0 }}</span>{% endif %}
      </div>

      <button type="submit" class="btn btn-primary btn-lg" style="width:100%;justify-content:center;">
        Create My Account →
      </button>
    </form>

    <p style="text-align:center;margin-top:20px;font-size:14px;color:var(--ink-4);">
      Already have an account?
      <a href="{% url 'knowledge_base:login' %}" style="color:var(--red);font-weight:500;">Sign in</a>
    </p>

  </div>
</div>
{% endblock %}
</file>

<file path="knowledge_base/templates/knowledge_base/base.html">
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}ACT InnerCircle{% endblock %}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display&display=swap" rel="stylesheet">
  <style>
    /* ── Design Tokens ───────────────────────────────────────── */
    :root {
      --red:         #D42B2B;
      --red-dark:   #B01E1E;
      --red-light:  #FFF0F0;
      --red-mid:     #F9DADA;
      --ink:         #1A1A2E;
      --ink-2:       #3D3D56;
      --ink-3:       #6B6B85;
      --ink-4:       #9999AF;
      --surface:     #FFFFFF;
      --bg:          #F4F5F7;
      --bg-2:        #ECEEF2;
      --border:      #E4E6EC;
      --border-2:    #D0D3DE;
      --shadow-sm:   0 1px 3px rgba(26,26,46,.06), 0 1px 2px rgba(26,26,46,.04);
      --shadow-md:   0 4px 12px rgba(26,26,46,.08), 0 2px 4px rgba(26,26,46,.04);
      --shadow-lg:   0 12px 32px rgba(26,26,46,.12), 0 4px 8px rgba(26,26,46,.06);
      --radius-sm:   6px;
      --radius-md:   10px;
      --radius-lg:   16px;
      --radius-xl:   24px;
      --nav-h:       64px;
      --sidebar-w:   240px;
      --rsidebar-w: 288px;
      --font:        'DM Sans', system-ui, sans-serif;
      --font-serif: 'DM Serif Display', Georgia, serif;
    }

    /* ── Reset ───────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--ink);
      font-size: 15px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    button, input, textarea, select {
      font-family: var(--font);
      font-size: 14px;
    }

    /* ── Top Navbar ──────────────────────────────────────────── */
    .navbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      height: var(--nav-h);
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      box-shadow: var(--shadow-sm);
      display: flex; align-items: center;
      padding: 0 24px; gap: 16px;
    }
    .navbar-brand {
      display: flex; align-items: center; gap: 10px;
      flex-shrink: 0;
    }
    .navbar-logo {
      width: 36px; height: 36px; border-radius: 8px;
      background: var(--red);
      display: flex; align-items: center; justify-content: center;
      color: white; font-weight: 700; font-size: 18px;
      letter-spacing: -1px;
    }
    .navbar-name {
      font-weight: 600; font-size: 16px; color: var(--ink);
      letter-spacing: -.2px;
    }
    .navbar-name span { color: var(--red); }

    /* Search bar */
    .navbar-search {
      flex: 1; max-width: 440px; margin: 0 auto;
      position: relative;
    }
    .navbar-search input {
      width: 100%;
      padding: 9px 16px 9px 40px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 24px;
      font-size: 14px;
      color: var(--ink);
      outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .navbar-search input::placeholder { color: var(--ink-4); }
    .navbar-search input:focus {
      border-color: var(--red);
      box-shadow: 0 0 0 3px rgba(212,43,43,.1);
      background: var(--surface);
    }
    .navbar-search-icon {
      position: absolute; left: 13px; top: 50%; transform: translateY(-50%);
      color: var(--ink-4); font-size: 15px; pointer-events: none;
    }

    /* Nav right */
    .navbar-right {
      display: flex; align-items: center; gap: 8px; flex-shrink: 0; margin-left: auto;
    }
    .nav-btn {
      display: flex; align-items: center; gap: 6px;
      padding: 7px 14px; border-radius: 8px;
      font-size: 13.5px; font-weight: 500;
      border: none; cursor: pointer;
      transition: background .15s, color .15s, transform .1s;
    }
    .nav-btn:active { transform: scale(.97); }
    .nav-btn-ghost { background: transparent; color: var(--ink-2); }
    .nav-btn-ghost:hover { background: var(--bg); }
    .nav-btn-primary { background: var(--red); color: white; }
    .nav-btn-primary:hover { background: var(--red-dark); }

    /* Avatar */
    .nav-avatar {
      width: 34px; height: 34px; border-radius: 50%;
      background: var(--red); color: white;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 600;
      cursor: pointer; flex-shrink: 0;
      overflow: hidden;
      border: 2px solid transparent;
      transition: border-color .2s;
    }
    .nav-avatar:hover { border-color: var(--red); }
    .nav-avatar img { width: 100%; height: 100%; object-fit: cover; }

    /* Mobile hamburger */
    .hamburger {
      display: none; flex-direction: column; gap: 5px;
      cursor: pointer; padding: 4px; background: none; border: none;
    }
    .hamburger span {
      display: block; width: 22px; height: 2px;
      background: var(--ink); border-radius: 2px;
      transition: .2s;
    }

    /* ── Page Shell ──────────────────────────────────────────── */
    .page-shell {
      display: flex;
      padding-top: var(--nav-h);
      min-height: 100vh;
    }

    /* ── Left Sidebar ────────────────────────────────────────── */
    .sidebar-left {
      position: fixed; top: var(--nav-h); left: 0; bottom: 0;
      width: var(--sidebar-w);
      background: var(--surface);
      border-right: 1px solid var(--border);
      overflow-y: auto;
      padding: 20px 12px;
      display: flex; flex-direction: column; gap: 2px;
      z-index: 50;
      transition: transform .3s;
    }
    .sidebar-label {
      font-size: 10.5px; font-weight: 600; letter-spacing: .8px;
      color: var(--ink-4); text-transform: uppercase;
      padding: 12px 12px 4px;
    }
    .sidebar-link {
      display: flex; align-items: center; gap: 10px;
      padding: 9px 12px; border-radius: var(--radius-md);
      font-size: 14px; font-weight: 500; color: var(--ink-2);
      transition: background .15s, color .15s;
      cursor: pointer;
    }
    .sidebar-link:hover { background: var(--bg); color: var(--ink); }
    .sidebar-link.active {
      background: var(--red-light); color: var(--red);
    }
    .sidebar-link .icon { font-size: 17px; flex-shrink: 0; }
    .sidebar-badge {
      margin-left: auto; background: var(--red); color: white;
      font-size: 10px; font-weight: 600; padding: 2px 6px;
      border-radius: 10px; min-width: 18px; text-align: center;
    }

    /* ── Main Content ────────────────────────────────────────── */
    .main-content {
      flex: 1;
      margin-left: var(--sidebar-w);
      margin-right: var(--rsidebar-w);
      padding: 28px 32px;
      max-width: 100%;
    }

    /* ── Right Sidebar ───────────────────────────────────────── */
    .sidebar-right {
      position: fixed; top: var(--nav-h); right: 0; bottom: 0;
      width: var(--rsidebar-w);
      background: var(--surface);
      border-left: 1px solid var(--border);
      overflow-y: auto;
      padding: 20px 16px;
      display: flex; flex-direction: column; gap: 20px;
    }
    .widget { display: flex; flex-direction: column; gap: 10px; }
    .widget-title {
      font-size: 12px; font-weight: 600; letter-spacing: .7px;
      text-transform: uppercase; color: var(--ink-4);
      padding-bottom: 8px;
      border-bottom: 1px solid var(--border);
    }

    /* ── Flash Messages ──────────────────────────────────────── */
    .flash-wrap { margin-bottom: 20px; display: flex; flex-direction: column; gap: 8px; }
    .flash {
      padding: 12px 16px; border-radius: var(--radius-md);
      font-size: 14px; font-weight: 500;
      display: flex; align-items: center; gap: 10px;
      animation: fadeSlide .3s ease;
    }
    @keyframes fadeSlide {
      from { opacity: 0; transform: translateY(-8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .flash-success { background: #F0FDF4; color: #166534; border: 1px solid #BBF7D0; }
    .flash-error   { background: #FFF0F0; color: #991B1B; border: 1px solid #FECACA; }
    .flash-info    { background: #EFF6FF; color: #1E40AF; border: 1px solid #BFDBFE; }
    .flash-warning { background: #FFFBEB; color: #92400E; border: 1px solid #FDE68A; }
    .flash-default { background: #EFF6FF; color: #1E40AF; border: 1px solid #BFDBFE; }

    /* ── Cards ───────────────────────────────────────────────── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
    }

    /* ── Post Cards ──────────────────────────────────────────── */
    .post-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      display: flex; flex-direction: column;
      transition: box-shadow .2s, transform .2s;
    }
    .post-card:hover {
      box-shadow: var(--shadow-lg);
      transform: translateY(-2px);
    }
    .post-thumb {
      width: 100%; height: 180px;
      object-fit: cover;
      background: linear-gradient(135deg, var(--red-mid) 0%, var(--bg-2) 100%);
      display: flex; align-items: center; justify-content: center;
      font-size: 40px; flex-shrink: 0;
      position: relative; overflow: hidden;
    }
    .post-thumb-placeholder {
      width: 100%; height: 180px;
      background: linear-gradient(135deg, #FFF0F0 0%, #F4F5F7 100%);
      display: flex; align-items: center; justify-content: center;
      font-size: 36px; color: var(--red); opacity: .4;
      flex-shrink: 0;
    }
    .post-body { padding: 20px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .post-meta-top {
      display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    }
    .post-title {
      font-size: 17px; font-weight: 600; color: var(--ink);
      line-height: 1.4; letter-spacing: -.2px;
      transition: color .15s;
    }
    .post-card:hover .post-title { color: var(--red); }
    .post-excerpt {
      font-size: 13.5px; color: var(--ink-3); line-height: 1.6;
      display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .post-footer {
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 20px;
      border-top: 1px solid var(--border);
      background: var(--bg);
    }
    .post-author {
      display: flex; align-items: center; gap: 8px;
    }
    .post-author-avatar {
      width: 28px; height: 28px; border-radius: 50%;
      background: var(--red); color: white;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 600; flex-shrink: 0; overflow: hidden;
    }
    .post-author-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .post-author-name { font-size: 13px; font-weight: 500; color: var(--ink-2); }
    .post-author-date { font-size: 12px; color: var(--ink-4); }
    .post-stats {
      display: flex; align-items: center; gap: 12px;
    }
    .post-stat {
      display: flex; align-items: center; gap: 4px;
      font-size: 12.5px; color: var(--ink-4);
    }

    /* ── Badges & Chips ──────────────────────────────────────── */
    .badge {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 3px 9px; border-radius: 20px;
      font-size: 11.5px; font-weight: 600; letter-spacing: .1px;
    }
    .badge-red     { background: var(--red-light); color: var(--red); }
    .badge-green   { background: #F0FDF4; color: #15803D; }
    .badge-amber   { background: #FFFBEB; color: #B45309; }
    .badge-gray    { background: var(--bg-2); color: var(--ink-3); }
    .badge-blue    { background: #EFF6FF; color: #1D4ED8; }
    .badge-draft   { background: var(--bg-2); color: var(--ink-3); }
    .badge-pending { background: #FFFBEB; color: #B45309; }
    .badge-published { background: #F0FDF4; color: #15803D; }
    .badge-rejected  { background: var(--red-light); color: var(--red); }

    .chip {
      display: inline-flex; align-items: center;
      padding: 4px 12px; border-radius: 20px;
      font-size: 12.5px; font-weight: 500;
      border: 1px solid var(--border);
      color: var(--ink-3); background: var(--surface);
      cursor: pointer; transition: all .15s;
    }
    .chip:hover, .chip.active {
      background: var(--red); color: white; border-color: var(--red);
    }

    /* ── Buttons ─────────────────────────────────────────────── */
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 9px 18px; border-radius: var(--radius-md);
      font-size: 14px; font-weight: 500;
      border: none; cursor: pointer;
      transition: background .15s, box-shadow .15s, transform .1s;
      white-space: nowrap;
    }
    .btn:active { transform: scale(.97); }
    .btn-primary {
      background: var(--red); color: white;
      box-shadow: 0 1px 3px rgba(212,43,43,.35);
    }
    .btn-primary:hover {
      background: var(--red-dark);
      box-shadow: 0 4px 12px rgba(212,43,43,.4);
    }
    .btn-secondary {
      background: var(--surface); color: var(--ink-2);
      border: 1px solid var(--border);
    }
    .btn-secondary:hover { background: var(--bg); }
    .btn-ghost { background: transparent; color: var(--ink-2); padding: 9px 12px; }
    .btn-ghost:hover { background: var(--bg); }
    .btn-success {
      background: #16A34A; color: white;
      box-shadow: 0 1px 3px rgba(22,163,74,.3);
    }
    .btn-success:hover { background: #15803D; }
    .btn-warning { background: #F59E0B; color: white; }
    .btn-warning:hover { background: #D97706; }
    .btn-sm { padding: 6px 12px; font-size: 13px; border-radius: var(--radius-sm); }
    .btn-lg { padding: 12px 24px; font-size: 15px; border-radius: var(--radius-md); }

    /* ── Form Inputs ─────────────────────────────────────────── */
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-label {
      font-size: 13.5px; font-weight: 600; color: var(--ink-2);
    }
    .form-label .req { color: var(--red); margin-left: 2px; }
    .form-control {
      width: 100%;
      padding: 10px 14px;
      background: var(--bg);
      border: 1.5px solid var(--border);
      border-radius: var(--radius-md);
      font-size: 14px; color: var(--ink);
      outline: none;
      transition: border-color .2s, box-shadow .2s, background .2s;
    }
    .form-control::placeholder { color: var(--ink-4); }
    .form-control:focus {
      border-color: var(--red);
      box-shadow: 0 0 0 3px rgba(212,43,43,.1);
      background: var(--surface);
    }
    .form-hint { font-size: 12px; color: var(--ink-4); }
    .form-error { font-size: 12.5px; color: var(--red); }

    /* ── Section Headings ────────────────────────────────────── */
    .section-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 20px;
    }
    .section-title {
      font-size: 20px; font-weight: 600; color: var(--ink);
      letter-spacing: -.3px;
    }
    .section-subtitle { font-size: 14px; color: var(--ink-3); margin-top: 2px; }

    /* ── AI Summary Box ──────────────────────────────────────── */
    .ai-box {
      background: linear-gradient(135deg, #FFF8F0 0%, #FFF0F5 100%);
      border: 1px solid #F4C5C5;
      border-radius: var(--radius-md);
      padding: 14px 16px;
      display: flex; gap: 12px; align-items: flex-start;
    }
    .ai-icon {
      width: 28px; height: 28px; border-radius: 6px;
      background: var(--red); color: white;
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; flex-shrink: 0;
    }
    .ai-label {
      font-size: 11px; font-weight: 700; letter-spacing: .6px;
      text-transform: uppercase; color: var(--red); margin-bottom: 3px;
    }
    .ai-text { font-size: 13.5px; color: var(--ink-2); line-height: 1.65; }

    /* ── Divider ─────────────────────────────────────────────── */
    .divider { height: 1px; background: var(--border); margin: 20px 0; }

    /* ── Empty state ─────────────────────────────────────────── */
    .empty-state {
      text-align: center; padding: 48px 24px;
      display: flex; flex-direction: column; align-items: center; gap: 12px;
    }
    .empty-state-icon { font-size: 48px; opacity: .35; }
    .empty-state-title { font-size: 17px; font-weight: 600; color: var(--ink-2); }
    .empty-state-text { font-size: 14px; color: var(--ink-4); max-width: 320px; }

    /* ── Post grid ───────────────────────────────────────────── */
    .post-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
    }
    .post-list { display: flex; flex-direction: column; gap: 16px; }

    /* ── Logout form inline ──────────────────────────────────── */
    .logout-form { display: inline; }

    /* ── Responsive ──────────────────────────────────────────── */
    @media (max-width: 1200px) {
      .sidebar-right { display: none; }
      .main-content { margin-right: 0; }
    }
    @media (max-width: 768px) {
      .sidebar-left {
        transform: translateX(-100%);
      }
      .sidebar-left.open { transform: translateX(0); }
      .main-content { margin-left: 0; padding: 16px; }
      .hamburger { display: flex; }
      .navbar-name { display: none; }
      .post-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .navbar-search { display: none; }
    }
  </style>
  {% block extra_head %}{% endblock %}
</head>
<body>

<nav class="navbar">
  <button class="hamburger" onclick="toggleSidebar()" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>

  <a href="{% url 'knowledge_base:post_list' %}" class="navbar-brand">
    <div class="navbar-logo">⚡</div>
    <span class="navbar-name">ACT <span>InnerCircle</span></span>
  </a>

  <form class="navbar-search" action="{% url 'knowledge_base:search' %}" method="get">
    <span class="navbar-search-icon">🔍</span>
    <input type="text" name="q" placeholder="Search articles, topics, people…" autocomplete="off">
  </form>

  <div class="navbar-right">
    {% if user.is_authenticated %}
      {% if user.is_admin_user %}
        <a href="{% url 'knowledge_base:pending_comments' %}" class="btn nav-btn nav-btn-ghost" title="Pending Comments">
          💬 Queue 
          {% if pending_count > 0 %}
            <span class="sidebar-badge" style="margin-left:4px">{{ pending_count }}</span>
          {% endif %}
        </a>
      {% endif %}

      <a href="{% url 'knowledge_base:post_create' %}" class="btn nav-btn nav-btn-primary">
        ✦ Write Post
      </a>
      <a href="{% url 'knowledge_base:profile' %}" class="nav-avatar" title="{{ user.get_full_name }}">
        {% if user.avatar %}
          <img src="{{ user.avatar.url }}" alt="avatar">
        {% else %}
          {{ user.first_name|first|upper }}
        {% endif %}
      </a>
    {% else %}
      <a href="{% url 'knowledge_base:login' %}" class="btn nav-btn nav-btn-ghost">Sign in</a>
      <a href="{% url 'knowledge_base:register' %}" class="btn nav-btn nav-btn-primary">Join free</a>
    {% endif %}
  </div>
</nav>

<div class="page-shell">

  <aside class="sidebar-left" id="sidebarLeft">
    <div class="sidebar-label">Discover</div>
    <a href="{% url 'knowledge_base:post_list' %}" class="sidebar-link {% block nav_home %}{% endblock %}">
      <span class="icon">🏠</span> Home
    </a>
    <a href="{% url 'knowledge_base:search' %}" class="sidebar-link {% block nav_search %}{% endblock %}">
      <span class="icon">🔍</span> Explore
    </a>

    {% if user.is_authenticated %}
    <div class="divider" style="margin:8px 0"></div>
    <div class="sidebar-label">My Space</div>
    <a href="{% url 'knowledge_base:dashboard' %}" class="sidebar-link {% block nav_dash %}{% endblock %}">
      <span class="icon">📋</span> Dashboard
    </a>
    <a href="{% url 'knowledge_base:my_workspace' %}" class="sidebar-link {% block nav_workspace %}{% endblock %}">
      <span class="icon">💼</span> My Workspace
    </a>
    <a href="{% url 'knowledge_base:post_create' %}" class="sidebar-link {% block nav_write %}{% endblock %}">
      <span class="icon">✏️</span> Write Post
    </a>
    <a href="{% url 'knowledge_base:profile' %}" class="sidebar-link {% block nav_profile %}{% endblock %}">
      <span class="icon">👤</span> Profile
    </a>

    {% if user.is_admin_user %}
    <div class="divider" style="margin:8px 0"></div>
    <div class="sidebar-label">Admin</div>
    <a href="{% url 'knowledge_base:approval_queue' %}" class="sidebar-link {% block nav_queue %}{% endblock %}">
      <span class="icon">⏳</span> Approval Queue
    </a>
    <a href="{% url 'knowledge_base:pending_comments' %}" class="sidebar-link {% block nav_comments %}{% endblock %}">
      <span class="icon">💬</span> Comment Queue
      {% if pending_count > 0 %}
        <span class="sidebar-badge">{{ pending_count }}</span>
      {% endif %}
    </a>
    <a href="/admin/" class="sidebar-link">
      <span class="icon">⚙️</span> Admin Panel
    </a>
    {% endif %}

    <div class="divider" style="margin:8px 0"></div>
    <form method="post" action="{% url 'knowledge_base:logout' %}" class="logout-form">
      {% csrf_token %}
      <button type="submit" class="sidebar-link" style="width:100%; background:none; border:none; text-align:left; cursor:pointer; color:var(--ink-3);">
        <span class="icon">🚪</span> Sign out
      </button>
    </form>
    {% endif %}
  </aside>

  <main class="main-content">
    {% if messages %}
    <div class="flash-wrap">
      {% for message in messages %}
        <div class="flash flash-default">
          {% if 'success' in message.tags %}✓{% elif 'error' in message.tags %}✕{% elif 'warning' in message.tags %}⚠{% else %}ℹ{% endif %}
          {{ message }}
        </div>
      {% endfor %}
    </div>
    {% endif %}

    {% block content %}{% endblock %}
  </main>

  <aside class="sidebar-right">
    {% block right_sidebar %}
    <div class="widget">
      <div class="widget-title">🔥 Trending</div>
      <p style="font-size:13px;color:var(--ink-4);text-align:center;padding:12px 0">
        Visit the home page to see trending posts
      </p>
    </div>
    {% endblock %}
  </aside>

</div>

<script>
  function toggleSidebar() {
    document.getElementById('sidebarLeft').classList.toggle('open');
  }
  // Close sidebar on outside click (mobile)
  document.addEventListener('click', function(e) {
    const sb = document.getElementById('sidebarLeft');
    if (window.innerWidth <= 768 && sb.classList.contains('open')) {
      if (!sb.contains(e.target) && !e.target.closest('.hamburger')) {
        sb.classList.remove('open');
      }
    }
  });
</script>
{% block extra_js %}{% endblock %}
</body>
</html>
</file>

<file path="knowledge_base/templates/knowledge_base/dashboard.html">
{% extends "knowledge_base/base.html" %}
{% block title %}My Dashboard — ACT InnerCircle{% endblock %}
{% block nav_dash %}active{% endblock %}

{% block right_sidebar %}
<div class="widget">
  <div class="widget-title">👤 My Profile</div>
  <div style="display:flex;flex-direction:column;align-items:center;gap:10px;padding:8px 0;text-align:center;">
    <div class="nav-avatar" style="width:56px;height:56px;font-size:22px;">
      {% if user.avatar %}<img src="{{ user.avatar.url }}" alt="">
      {% else %}{{ user.first_name|first|upper }}{% endif %}
    </div>
    <div>
      <div style="font-weight:600;font-size:15px;">{{ user.get_full_name }}</div>
      <div style="font-size:12px;color:var(--ink-4);">{{ user.email }}</div>
    </div>
    <span class="badge {% if user.is_admin_user %}badge-red{% else %}badge-blue{% endif %}">
      {{ user.get_role_display }}
    </span>
  </div>
</div>

<div class="widget">
  <div class="widget-title">📊 Post Summary</div>
  <div style="display:flex;flex-direction:column;gap:8px;">
    <div style="display:flex;justify-content:space-between;align-items:center;font-size:13.5px;">
      <span style="color:var(--ink-3);">📝 Drafts</span>
      <span class="badge badge-gray">{{ draft_posts.count }}</span>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:center;font-size:13.5px;">
      <span style="color:var(--ink-3);">⏳ Pending</span>
      <span class="badge badge-pending">{{ pending_posts.count }}</span>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:center;font-size:13.5px;">
      <span style="color:var(--ink-3);">✅ Published</span>
      <span class="badge badge-published">{{ published_posts.count }}</span>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:center;font-size:13.5px;">
      <span style="color:var(--ink-3);">❌ Rejected</span>
      <span class="badge badge-rejected">{{ rejected_posts.count }}</span>
    </div>
  </div>
</div>
{% endblock %}

{% block content %}
<div class="section-header">
  <div>
    <h1 class="section-title">My Dashboard</h1>
    <p class="section-subtitle">Manage your articles and track their progress</p>
  </div>
  <a href="{% url 'knowledge_base:post_create' %}" class="btn btn-primary">✦ New Post</a>
</div>

<!-- Needs revision first (highest priority) -->
{% if rejected_posts %}
<div style="margin-bottom:20px;">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
    <h2 style="font-size:16px;font-weight:600;">❌ Needs Revision</h2>
    <span class="badge badge-rejected">{{ rejected_posts.count }}</span>
  </div>
  <div class="post-list">
    {% for post in rejected_posts %}
    <div class="card" style="padding:20px;border-left:3px solid var(--red);">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;">
        <div style="flex:1;">
          <div style="font-weight:600;font-size:15px;margin-bottom:6px;">{{ post.title }}</div>
          {% if post.rejection_reason %}
          <div style="display:flex;gap:8px;align-items:flex-start;background:var(--red-light);
                      border-radius:var(--radius-sm);padding:10px 12px;margin-bottom:10px;">
            <span style="color:var(--red);font-size:13px;">⚠ <strong>Feedback:</strong> {{ post.rejection_reason }}</span>
          </div>
          {% endif %}
          <div style="font-size:12.5px;color:var(--ink-4);">Updated {{ post.updated_at|date:"d M Y" }}</div>
        </div>
        <a href="{% url 'knowledge_base:post_submit' post.slug %}" class="btn btn-primary btn-sm">Resubmit</a>
      </div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

<!-- Pending approval -->
{% if pending_posts %}
<div style="margin-bottom:20px;">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
    <h2 style="font-size:16px;font-weight:600;">⏳ Awaiting Approval</h2>
    <span class="badge badge-pending">{{ pending_posts.count }}</span>
  </div>
  <div class="post-list">
    {% for post in pending_posts %}
    <div class="card" style="padding:20px;border-left:3px solid #F59E0B;">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
        <div>
          <div style="font-weight:600;font-size:15px;margin-bottom:4px;">{{ post.title }}</div>
          <div style="font-size:12.5px;color:var(--ink-4);">Submitted {{ post.updated_at|date:"d M Y" }} · Waiting for admin review</div>
        </div>
        <span class="badge badge-pending">⏳ Pending</span>
      </div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

<!-- Drafts -->
{% if draft_posts %}
<div style="margin-bottom:20px;">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
    <h2 style="font-size:16px;font-weight:600;">📝 Drafts</h2>
    <span class="badge badge-gray">{{ draft_posts.count }}</span>
  </div>
  <div class="post-list">
    {% for post in draft_posts %}
    <div class="card" style="padding:20px;">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
        <div>
          <div style="font-weight:600;font-size:15px;margin-bottom:4px;">{{ post.title }}</div>
          <div style="font-size:12.5px;color:var(--ink-4);">Last edited {{ post.updated_at|date:"d M Y" }}</div>
        </div>
        <a href="{% url 'knowledge_base:post_submit' post.slug %}" class="btn btn-secondary btn-sm">
          Submit for Review →
        </a>
      </div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

<!-- Published -->
{% if published_posts %}
<div style="margin-bottom:20px;">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
    <h2 style="font-size:16px;font-weight:600;">✅ Published</h2>
    <span class="badge badge-published">{{ published_posts.count }}</span>
  </div>
  <div class="post-list">
    {% for post in published_posts %}
    <div class="card" style="padding:20px;">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
        <div style="flex:1;">
          <a href="{% url 'knowledge_base:post_detail' post.slug %}"
             style="font-weight:600;font-size:15px;color:var(--red);">{{ post.title }}</a>
          <div style="font-size:12.5px;color:var(--ink-4);margin-top:3px;">Published {{ post.published_at|date:"d M Y" }}</div>
        </div>
        <div class="post-stats">
          <span class="post-stat">👍 {{ post.upvote_count }}</span>
          <span class="post-stat">💬 {{ post.comment_count }}</span>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

<!-- Empty state -->
{% if not draft_posts and not pending_posts and not published_posts and not rejected_posts %}
<div class="card">
  <div class="empty-state">
    <div class="empty-state-icon">✨</div>
    <div class="empty-state-title">Your dashboard is empty</div>
    <div class="empty-state-text">Share your knowledge with the ACT team. Write your first article to get started.</div>
    <a href="{% url 'knowledge_base:post_create' %}" class="btn btn-primary" style="margin-top:8px;">Write your first post</a>
  </div>
</div>
{% endif %}
{% endblock %}
</file>

<file path="knowledge_base/templates/knowledge_base/my_workspace.html">
{% extends "knowledge_base/base.html" %}
{% load static %}

{% block title %}My Workspace — ACT InnerCircle{% endblock %}

{% block content %}

{# ═══════════════════════════════════════════════════════════════════════
   DATA BRIDGE — Django → JavaScript via json_script (XSS-safe).

   NEVER write: var data = {{ pie_data }};  ← XSS vulnerability
   ALWAYS use:  JSON.parse(document.getElementById('id').textContent)

   json_script renders a hidden <script type="application/json"> tag
   that browsers treat as inert data, not executable code.
═══════════════════════════════════════════════════════════════════════ #}
{{ pie_labels|json_script:"js-pie-labels" }}
{{ pie_data|json_script:"js-pie-data" }}
{{ daily_labels|json_script:"js-daily-labels" }}
{{ daily_data|json_script:"js-daily-data" }}


<div class="ws-page">

  <!-- ══════════════════════════════════════════════════════
       HERO — Personal greeting + identity strip
  ══════════════════════════════════════════════════════ -->
  <header class="ws-hero">
    <div class="ws-hero-left">
      <div class="ws-hero-avatar">
        {% if user.avatar %}
          <img src="{{ user.avatar.url }}" alt="{{ user.get_full_name }}" class="ws-avatar-img">
        {% else %}
          <span class="ws-avatar-initials">
            {{ user.first_name|first|upper }}{{ user.last_name|first|upper }}
          </span>
        {% endif %}
        <span class="ws-avatar-ring"></span>
      </div>
      <div class="ws-hero-text">
        <p class="ws-hero-greeting">Good {% now "G" as h %}{% if h < 12 %}morning{% elif h < 17 %}afternoon{% else %}evening{% endif %},</p>
        <h1 class="ws-hero-name">{{ user.first_name|default:user.email }}</h1>
        <p class="ws-hero-meta">
          {{ user.department|default:"ACT Fibernet" }}
          <span class="ws-dot">·</span>
          Member since {{ user.date_joined|date:"M Y" }}
        </p>
      </div>
    </div>
    <div class="ws-hero-right">
      <a href="{% url 'post_create' %}" class="ws-btn ws-btn--primary">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        New Post
      </a>
      <a href="{% url 'profile' %}" class="ws-btn ws-btn--ghost">Edit Profile</a>
    </div>
  </header>

  <!-- ══════════════════════════════════════════════════════
       KPI STRIP — 4 summary numbers
  ══════════════════════════════════════════════════════ -->
  <section class="ws-kpi-strip" aria-label="Your stats">

    <div class="ws-kpi ws-kpi--hero">
      <div class="ws-kpi-inner">
        <span class="ws-kpi-num" data-target="{{ posts_total }}">0</span>
        <span class="ws-kpi-label">Total Posts</span>
      </div>
      <div class="ws-kpi-sub-grid">
        <span class="ws-kpi-sub">
          <span class="ws-kpi-sub-dot ws-kpi-sub-dot--published"></span>
          {{ posts_published }} published
        </span>
        <span class="ws-kpi-sub">
          <span class="ws-kpi-sub-dot ws-kpi-sub-dot--draft"></span>
          {{ posts_draft }} draft
        </span>
        {% if posts_pending %}
        <span class="ws-kpi-sub">
          <span class="ws-kpi-sub-dot ws-kpi-sub-dot--pending"></span>
          {{ posts_pending }} pending
        </span>
        {% endif %}
        {% if posts_rejected %}
        <span class="ws-kpi-sub">
          <span class="ws-kpi-sub-dot ws-kpi-sub-dot--rejected"></span>
          {{ posts_rejected }} rejected
        </span>
        {% endif %}
      </div>
    </div>

    <div class="ws-kpi">
      <svg class="ws-kpi-icon" width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M12 4l2.09 6.26L20 12l-5.91 1.74L12 20l-2.09-6.26L4 12l5.91-1.74L12 4z"
              stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      </svg>
      <span class="ws-kpi-num" data-target="{{ total_likes }}">0</span>
      <span class="ws-kpi-label">Likes received</span>
    </div>

    <div class="ws-kpi">
      <svg class="ws-kpi-icon" width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
              stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      </svg>
      <span class="ws-kpi-num" data-target="{{ total_comments }}">0</span>
      <span class="ws-kpi-label">Comments received</span>
    </div>

    <div class="ws-kpi">
      <svg class="ws-kpi-icon" width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="ws-kpi-num" data-target="{{ posts_published }}">0</span>
      <span class="ws-kpi-label">Published posts</span>
    </div>

  </section>

  <!-- ══════════════════════════════════════════════════════
       CHARTS ROW — Pie (status) + Line (daily likes)
  ══════════════════════════════════════════════════════ -->
  <section class="ws-charts-row" aria-label="Charts">

    <!-- Pie chart: post status distribution -->
    <div class="ws-chart-card ws-chart-card--pie">
      <div class="ws-chart-header">
        <div>
          <h2 class="ws-chart-title">Post Status</h2>
          <p class="ws-chart-sub">Distribution across all your posts</p>
        </div>
      </div>

      {% if posts_total > 0 %}
        <div class="ws-pie-layout">
          <!-- Canvas gets a fixed square so the doughnut renders correctly -->
          <div class="ws-pie-canvas-wrap">
            <canvas id="pieChart" width="200" height="200"></canvas>
            <!-- Centred label inside the doughnut hole -->
            <div class="ws-pie-centre">
              <span class="ws-pie-centre-num">{{ posts_total }}</span>
              <span class="ws-pie-centre-label">total</span>
            </div>
          </div>
          <!-- Custom legend — Chart.js default legend is hard to style -->
          <ul class="ws-pie-legend" id="pieLegend" aria-label="Status legend"></ul>
        </div>
      {% else %}
        <div class="ws-empty-state">
          <div class="ws-empty-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z"
                    stroke="currentColor" stroke-width="1.4"/>
              <path d="M14 2v6h6" stroke="currentColor" stroke-width="1.4"/>
            </svg>
          </div>
          <p class="ws-empty-text">Create your first post to see your status breakdown.</p>
          <a href="{% url 'post_create' %}" class="ws-btn ws-btn--primary ws-btn--sm">Write a post</a>
        </div>
      {% endif %}
    </div>

    <!-- Line chart: daily likes over 30 days -->
    <div class="ws-chart-card ws-chart-card--line">
      <div class="ws-chart-header">
        <div>
          <h2 class="ws-chart-title">Likes — Last 30 Days</h2>
          <p class="ws-chart-sub">Daily upvotes received on your posts</p>
        </div>
        <div class="ws-chart-total-badge">
          <span class="ws-chart-total-num">{{ total_likes }}</span>
