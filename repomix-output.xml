                {% if post.category %}
                  <span class="ws-chip">{{ post.category.name }}</span>
                {% endif %}
              </td>
              <td class="ws-td-num ws-td-likes">
                <span>{{ post.like_count }}</span>
              </td>
              <td class="ws-td-num">
                <span>{{ post.comment_count }}</span>
