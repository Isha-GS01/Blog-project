          </tbody>
        </table>
      {% else %}
        <div class="ws-empty-state ws-empty-state--table">
          <p class="ws-empty-text">No published posts yet. Once you publish, your top posts appear here.</p>
        </div>
      {% endif %}
    </div>

    <!-- Recent activity sidebar -->
    <div class="ws-activity-card">
      <div class="ws-table-header">
        <h2 class="ws-table-title">Recent Posts</h2>
        <span class="ws-table-badge">Last 10</span>
      </div>
      <ul class="ws-activity-list">
        {% for post in recent_posts %}
        <li class="ws-activity-item">
          <div class="ws-activity-status-bar ws-activity-status-bar--{{ post.status|lower }}"></div>
          <div class="ws-activity-body">
            <a href="{% url 'post_detail' post.slug %}" class="ws-activity-title">
              {{ post.title|truncatechars:45 }}
            </a>
            <div class="ws-activity-meta">
              <span class="ws-status-badge ws-status-badge--{{ post.status|lower }} ws-status-badge--xs">
                {{ post.get_status_display }}
              </span>
              <span class="ws-activity-date">{{ post.created_at|date:"d M" }}</span>
            </div>
          </div>
          <div class="ws-activity-actions">
            <a href="{% url 'post_detail' post.slug %}" class="ws-icon-btn" title="View">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="1.8"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8"/>
              </svg>
            </a>
          </div>
        </li>
        {% empty %}
        <li class="ws-empty-state">
          <p class="ws-empty-text">No posts yet.</p>
        </li>
        {% endfor %}
      </ul>
    </div>

  </section>

