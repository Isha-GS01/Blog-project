  <!-- ══════════════════════════════════════════════════════
       BOTTOM ROW — Top posts table + Recent activity
  ══════════════════════════════════════════════════════ -->
  <section class="ws-bottom-row" aria-label="Posts detail">

    <!-- Top performing posts -->
    <div class="ws-table-card">
      <div class="ws-table-header">
        <h2 class="ws-table-title">Top Performing Posts</h2>
        <span class="ws-table-badge">By likes</span>
      </div>

      {% if top_posts %}
        <table class="ws-table">
          <thead>
            <tr>
              <th class="ws-th-rank">#</th>
              <th>Post</th>
              <th class="ws-th-num">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                  <path d="M12 4l2.09 6.26L20 12l-5.91 1.74L12 20l-2.09-6.26L4 12l5.91-1.74L12 4z"
                        stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                </svg>
              </th>
              <th class="ws-th-num">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                  <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
                        stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                </svg>
              </th>
              <th class="ws-th-status">Status</th>
              <th class="ws-th-date">Published</th>
