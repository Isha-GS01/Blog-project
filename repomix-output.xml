            <tr class="ws-tr">
              <td class="ws-td-rank">
                {% if forloop.counter == 1 %}
                  <span class="ws-medal ws-medal--gold">1</span>
                {% elif forloop.counter == 2 %}
                  <span class="ws-medal ws-medal--silver">2</span>
                {% elif forloop.counter == 3 %}
                  <span class="ws-medal ws-medal--bronze">3</span>
                {% else %}
                  <span class="ws-rank-plain">{{ forloop.counter }}</span>
                {% endif %}
              </td>
              <td class="ws-td-title">
                <a href="{% url 'post_detail' post.slug %}" class="ws-post-link">
                  {{ post.title|truncatechars:55 }}
